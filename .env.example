# --- Application ----------------------------------------------------------
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --- Server ---------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# --- Database -------------------------------------------------------------
# Local default (no infra needed):
DATABASE_URL=sqlite+aiosqlite:///./makor_dev.db
# Production / Docker:
# DATABASE_URL=postgresql+asyncpg://makor:makor@db:5432/makor
DB_ECHO=false

# --- Anthropic (used in a later phase) ------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# --- Briefing settings ----------------------------------------------------
BRIEFING_TIMEZONE=Europe/London
BRIEFING_DESK=Makor Macro & FX Desk
BRIEFING_GENERATOR_VERSION=mock-v1
