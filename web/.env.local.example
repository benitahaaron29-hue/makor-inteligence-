# Origin of the data service. Next.js proxies /api/* to ${API_ORIGIN}/api/*.
# Defaults to http://127.0.0.1:8000 — change for production deploys.
NEXT_PUBLIC_API_ORIGIN=http://127.0.0.1:8000

# Demo mode — when "true", the frontend never calls the data service.
# Every briefing / archive / sources fetch is served from bundled JSON
# in web/lib/api/mocks/ (imported statically at build time, inlined into
# the bundle). Use this for Vercel deployments that have no upstream
# backend (e.g. preview / share-with-stakeholders builds).
#
# When unset or "false", the frontend tries the live API first and falls
# back to the bundled JSON only if the call fails.
NEXT_PUBLIC_DEMO_MODE=false

# ----------------------------------------------------------------------
# Narrative LLM provider
# ----------------------------------------------------------------------
#
# The narrative service (lib/narrative/) calls one LLM provider per
# briefing to synthesise the executive summary, strategist view, macro
# overview, what-changed, and asset-class commentary. Provider selection
# is a single env var — no code change needed to swap vendors.
#
#   LLM_PROVIDER=openrouter  (default when unset)
#   LLM_PROVIDER=anthropic
#
# Optional model override (provider-agnostic; the value is whatever the
# chosen provider accepts as a model id):
#
#   LLM_MODEL=deepseek/deepseek-chat       (OpenRouter default)
#   LLM_MODEL=claude-sonnet-4-6            (Anthropic default)
#   LLM_MODEL=openai/gpt-4o-mini           (OpenRouter alias example)
#
# NARRATIVE_MODEL is still honoured as a back-compat alias for LLM_MODEL.
LLM_PROVIDER=openrouter
LLM_MODEL=deepseek/deepseek-chat

# ----------------------------------------------------------------------
# Provider API keys (server-only — never prefix NEXT_PUBLIC_)
# ----------------------------------------------------------------------
#
# Set the key matching the active provider. If the key is missing the
# briefing renders with template content (no synthesis), the diagnostic
# /api/diag surfaces last_result: "no-key", and per-field source map
# shows "template" for every field.
#
# OPENROUTER_API_KEY=sk-or-v1-...
# ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------------------
# Calendar provider (TradingEconomics)
# ----------------------------------------------------------------------
# Without a registered key, the calendar adapter falls back to the
# public "guest:guest" sandbox (limited country coverage).
# TRADINGECONOMICS_KEY=<your-key>
